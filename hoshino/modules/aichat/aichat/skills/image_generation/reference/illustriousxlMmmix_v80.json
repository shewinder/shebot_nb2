{
  "1": {
    "inputs": {
      "ckpt_name": "illustriousxlMmmix_v80.safetensors"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": {
      "title": "Checkpoint加载器"
    }
  },
  "2": {
    "inputs": {
      "text": "{{prompt}}",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "正面提示词"
    }
  },
  "3": {
    "inputs": {
      "text": "worst quality, low quality, jpeg artifacts, 3d, multiple views, 4koma, bad anatomy, bad hands, text",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "负面提示词"
    }
  },
  "4": {
    "inputs": {
      "width": 1024,
      "height": 1536,
      "batch_size": 1
    },
    "class_type": "EmptyLatentImage",
    "_meta": {
      "title": "空Latent图像"
    }
  },
  "5": {
    "inputs": {
      "seed": 12345,
      "steps": 25,
      "cfg": 5,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1,
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0]
    },
    "class_type": "KSampler",
    "_meta": {
      "title": "K采样器"
    }
  },
  "6": {
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {
      "title": "VAE解码"
    }
  },
  "7": {
    "inputs": {
      "filename_prefix": "illustriousxlMmmix_v80",
      "images": ["6", 0]
    },
    "class_type": "SaveImage",
    "_meta": {
      "title": "保存图像"
    }
  }
}
