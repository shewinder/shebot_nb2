services:
  shebot:
    image: shebot:latest
    restart: always
    ports:
      - 9000:9000
    working_dir: /app
    volumes:
      - hinata_data:/app/data
      - ./.env.prod:/app/.env.prod
      - ./logs/:/app/logs/
    networks:
      - app-network
    depends_on:
      - browser
    environment:
      # 浏览器服务地址（容器内通信）
      - BROWSER_WS_URL=ws://browser:3000/chromium?launch={"headless":false}

  llonebot:
    volumes:
        - ./QQ:/root/.config/QQ # 挂载 QQ 配置目录
        - ./llonebot:/root/llonebot # 挂载 llonebot 数据目录
        - hinata_data:/app/data 
    ports:
        - 3000:3000 # OneBot HTTP 端口
        - 3001:3001 # OneBot WebSocket 端口
        - 5600:5600 # Satori 端口
        - 3080:3080 # webui
    restart: always
    image: initialencounter/llonebot:latest
    networks:
      - app-network

  # Browserless Chrome - 独立的浏览器服务
  # 为 Playwright 提供远程浏览器连接
  browser:
    image: browserless/chrome:latest
    restart: always
    ports:
      - 3003:3000  # 浏览器服务端口（外部访问）
    environment:
      # 最大并发会话数
      - MAX_CONCURRENT_SESSIONS=5
      # 会话超时时间（毫秒）
      - CONNECTION_TIMEOUT=300000
      # 空闲超时时间（毫秒）
      - MAX_IDLE_TIME=60000
      # 启用调试
      - DEBUG=browserless:*
      # 默认启动参数
      - DEFAULT_HEADLESS=false
      # 启用 DevTools
      - ENABLE_DEBUG_VIEWER=true
    networks:
      - app-network
    # 资源限制（可选）
    # deploy:
    #   resources:
    #     limits:
    #       memory: 2G
    #     reservations:
    #       memory: 512M

volumes:
  hinata_data:
    driver: local

networks:
  app-network:
    driver: bridge
    name: app-network
