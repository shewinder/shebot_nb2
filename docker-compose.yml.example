services:
  shebot:
    container_name: hinata
    image: shewinder/shebot:latest
    restart: always
    ports:
      - 9000:9000
    working_dir: /app
    volumes:
      # 共享数据目录（与 llbot 共享）
      - ./data/shared:/app/data
      # 环境配置
      - ./.env.prod:/app/.env.prod
      - ./logs:/app/logs
    networks:
      - bot-network
    depends_on:
      - browser
    environment:
      # 浏览器服务地址（容器内通信）
      - BROWSER_WS_URL=ws://localhost:3003/chromium?launch={"headless":false}

  # QQ 客户端 (PMHQ)
  pmhq:
    image: linyuchen/pmhq:7.3.0
    container_name: pmhq
    privileged: true
    environment:
      - ENABLE_HEADLESS=false
    networks:
      - bot-network
    volumes:
      # QQ 数据目录（与 llbot 共享，使用容器卷）
      - qq_config:/root/.config/QQ
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:13000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

  # LLBot (本地构建，含 120s 超时修改)
  llonebot:
    container_name: llob
    image: linyuchen/llonebot:latest
    ports:
      - 3080:3080
    environment:
      - pmhq_host=pmhq
      - pmhq_port=13000
      - WEBUI_PORT=3080
    networks:
      - bot-network
    volumes:
      # LLBot 数据目录
      - ./data/llbot:/app/llbot/data
      # 共享数据目录（与 shebot 共享）
      - ./data/shared:/app/data
      # QQ 数据目录（与 pmhq 共享，使用容器卷）
      - qq_config:/root/.config/QQ
    depends_on:
      - pmhq
    restart: unless-stopped

  # Browserless Chrome - 独立的浏览器服务
  # 为 Playwright 提供远程浏览器连接
  browser:
    image: browserless/chrome:latest
    restart: always
    ports:
      - 3003:3000  # 浏览器服务端口（外部访问）
    environment:
      # 最大并发会话数
      - MAX_CONCURRENT_SESSIONS=5
      # 会话超时时间（毫秒）
      - CONNECTION_TIMEOUT=300000
      # 空闲超时时间（毫秒）
      - MAX_IDLE_TIME=60000
      # 启用调试
      - DEBUG=browserless:*
      # 默认启动参数
      - DEFAULT_HEADLESS=false
      # 启用 DevTools
      - ENABLE_DEBUG_VIEWER=true
    networks:
      - bot-network
    # 资源限制（可选）
    # deploy:
    #   resources:
    #     limits:
    #       memory: 2G
    #     reservations:
    #       memory: 512M

  # Playwright MCP Server - AI 浏览器自动化
  # 通过 MCP 协议让 AI 控制浏览器
  playwright-mcp:
    image: mcr.microsoft.com/playwright/mcp:latest
    container_name: playwright-mcp
    restart: always
    ports:
      - "8931:8931"  # MCP SSE 端口
    environment:
      # 无头模式运行
      - PW_HEADLESS=true
    # 镜像已自带启动参数: node cli.js --headless --browser chromium --no-sandbox
    # 只需指定端口参数
    command: ["--port", "8931"]
    networks:
      - bot-network
    # 资源限制（可选）
    # deploy:
    #   resources:
    #     limits:
    #       memory: 2G
    #     reservations:
    #       memory: 1G

volumes:
  # QQ 配置数据卷（pmhq 和 llbot 共享）
  qq_config:
    driver: local

networks:
  bot-network:
    driver: bridge
    name: bot-network
